ip address add 100.0.0.1/24 dev eth0
ip address add 200.0.0.1/24 dev eth1

# for limited bandwidth
# tc qdisc add dev eth1 root tbf rate 256kbit buffer 2kb latency 50ms

# for fixed delay
# tc qdisc add dev eth0 root netem delay 10ms

# for variable delay
# tc qdisc add dev eth0 root netem delay 10ms 5ms

#for packet loss
tc qdisc add dev eth0 root netem delay 10ms loss 10%
